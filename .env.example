# ============================================================
# WILDFIRENET — Environment Variables Template
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ============================================================

# NASA FIRMS (https://firms.modaps.eosdis.nasa.gov/api/map_key/)
NASA_FIRMS_API_KEY=your_firms_api_key_here
NASA_FIRMS_MAP_KEY=your_firms_map_key_here

# EPA AirNow (https://docs.airnowapi.org/account/request/)
EPA_AIRNOW_API_KEY=your_airnow_key_here

# Twilio SMS Alerts (https://www.twilio.com/try-twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# SendGrid Email (https://signup.sendgrid.com/)
SENDGRID_API_KEY=your_sendgrid_key_here
ALERT_FROM_EMAIL=alerts@wildfirenet.dev

# Mapbox (https://account.mapbox.com/auth/signup/)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Dryad Silvanet (partnership — https://www.dryad.net/contact)
DRYAD_API_KEY=your_dryad_key_here
DRYAD_API_BASE_URL=https://api.silvanet.dryad.net/v1

# Database
DB_CONNECTION_STRING=sqlite:///./wildfirenet.db

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
ALERT_WEBHOOK_URL=your_cad_webhook_here
PORT=8000